{
  "name": "bloom",
  "private": true,
  "version": "0.1.0",
  "description": "Configurable web interface framework for robot teleoperation, supervision, and device control.",
  "workspaces": [
    "frontend/apps/*",
    "frontend/libs/*"
  ],
  "scripts": {
