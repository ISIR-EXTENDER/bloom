{
  "name": "bloom",
  "private": true,
  "version": "0.1.0",
  "description": "Configurable web interface framework for robot teleoperation, supervision, and device control.",
  "workspaces": [
    "frontend/apps/*",
    "frontend/libs/*"
  ],
  "scripts": {
    "audit:backend": "cd backend && make audit",
    "audit:frontend": "npm audit --audit-level=moderate",
    "audit:security": "npm run audit:frontend && npm run audit:backend",
    "build": "npm run build --workspaces --if-present",
    "capture:readme": "node scripts/capture-readme-screenshots.mjs",
    "check": "biome check .",
    "format": "biome check --write .",
    "dev": "npm run dev --workspace @bloom/dashboard",
    "test": "npm run test --workspaces --if-present",
    "security:dynamic": "node scripts/dynamic-security-smoke.mjs",
    "validation:extender": "bash scripts/extender-validation-preflight.sh",
    "validation:sandbox-tablet": "node scripts/sandbox-tablet-layout-check.mjs",
    "validation:sandbox-runtime": "node scripts/sandbox-runtime-contract.mjs",
    "validation:visual-servoing": "node scripts/visual-servoing-contract.mjs",
    "visual:smoke": "node scripts/visual-smoke.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@playwright/test": "^1.60.0"
  }
}
