{
  "name": "bloom",
  "private": true,
  "version": "0.1.0",
  "description": "Configurable web interface framework for robot teleoperation, supervision, and device control.",
  "workspaces": [
    "frontend/apps/*",
    "frontend/libs/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "check": "biome check .",
    "format": "biome check --write .",
    "dev": "npm run dev --workspace @bloom/dashboard",
    "test": "npm run test --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16"
  }
}
